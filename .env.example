# Copy this file to .env for local Docker Compose runs.
# Keep .env private and choose local-only values.

MONGO_ROOT_USERNAME=iot_admin
MONGO_ROOT_PASSWORD=replace_with_local_mongo_secret
MONGO_DATABASE=iot_data

MONGO_EXPRESS_BASICAUTH_USERNAME=iot_admin
MONGO_EXPRESS_BASICAUTH_PASSWORD=replace_with_local_web_secret

REACT_APP_API_URL=http://localhost:8000
